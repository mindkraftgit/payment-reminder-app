# CI/CD Workflow for Payment Reminder App
# Runs on every pull request and commit to main
# Tests are a prerequisite for merges

name: CI

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main, develop]

jobs:
  # Type check and lint with pre-commit hook
  typecheck:
    name: TypeScript & Lint & Pre-commit Hook
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'pnpm'
        
      - name: Install dependencies
        run: pnpm install --frozen-lockfile
        
      - name: Run pre-commit hook (tests)
        uses: actions/github-script@v7
        with:
          script: |
            try {
              exec('git diff-index --name-only HEAD -- | grep -qE "\\.(tsx?|jsx?)$" || exit 0;
                    npm test -- --run __tests__/');
            } catch (err) {
              core.setFailed(`Pre-commit tests failed: ${err.message}`);
            }
        
      - name: Run TypeScript typecheck
        run: pnpm run typecheck
        
      - name: Run linting
        run: pnpm run lint
        
  # Test suite
  test:
    name: Tests
    runs-on: ubuntu-latest
    needs: [typecheck]
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'pnpm'
        
      - name: Install dependencies
        run: pnpm install --frozen-lockfile
        
      - name: Run tests with coverage
        run: pnpm run test:coverage
        env:
          CI: true
        
      - name: Upload coverage reports to Codecov
        uses: codecov/codecov-action@v3
        with:
          files: ./coverage/
          fail_ci_if_error: false

  # Build preview
  build:
    name: Build
    runs-on: ubuntu-latest
    needs: [typecheck, test]
    steps:
      - uses: actions/checkout@v4
        
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'pnpm'
        
      - name: Install dependencies
        run: pnpm install --frozen-lockfile
        
      - name: Build application
        run: pnpm build
        
      - name: Upload production build
        uses: actions/upload-artifact@v4
        with:
          name: dist
          path: dist/
