{
  "name": "payment-reminder-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://mindkraftgit.github.io/payment-reminder-app",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
